# Supabase credentials — copy this file to `.env` and fill in your project's
# values (Supabase dashboard → Project Settings → API). The same two vars must
# also be set in the Vercel project (Settings → Environment Variables).
#
# Without these the app still runs read-only (auth + contributions disabled).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
